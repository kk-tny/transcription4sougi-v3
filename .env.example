# Gemini API Key
GEMINI_API_KEY=

# Google Sheets API Configuration
# GCPからダウンロードしたJSONファイルの中身を1行の文字列として貼り付けてください
GOOGLE_SHEETS_JSON_KEY=
# 操作対象のスプレッドシートID（URLの /d/ と /edit の間の文字列）
SPREADSHEET_ID=

# 自動連携用スプレッドシートID（コールデータバンク用）
AUTO_ANALYSIS_SPREADSHEET_ID=

# Call Data Bank (Lograph) API Credentials
CDB_EMAIL=
CDB_PASSWORD=
CDB_SERVICE_CONSUMER_ID=1

# Chatwork Notification Settings
CHATWORK_API_TOKEN=
CHATWORK_ROOM_ID=

# Security Token for triggering analysis (Cloud Scheduler logic)
TRIGGER_TOKEN=
